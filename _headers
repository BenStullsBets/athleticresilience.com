# Cloudflare Pages — response headers for all routes
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; frame-src https://challenges.cloudflare.com; form-action 'self' https://api.web3forms.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://challenges.cloudflare.com; connect-src 'self' https://cloudflareinsights.com https://api.web3forms.com https://challenges.cloudflare.com; upgrade-insecure-requests

# CSS/JS filenames are not fingerprinted and change often during iteration, so
# revalidate them on every load (cheap 304s) — otherwise an immutable cache would
# keep serving a stale stylesheet after a deploy.
/styles.css
  Cache-Control: public, max-age=0, must-revalidate
/script.js
  Cache-Control: public, max-age=0, must-revalidate

# Fonts and media are stable assets — keep them long-lived.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/media/*
  Cache-Control: public, max-age=31536000
/images/*
  Cache-Control: public, max-age=31536000
